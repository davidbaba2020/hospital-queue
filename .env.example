# ══════════════════════════════════════════════════════════════
# MediQueue — Environment Variables
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════════════

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_DB=hospitaldb
POSTGRES_USER=hospitaluser
POSTGRES_PASSWORD=your_secure_db_password_here

# ── JWT ─────────────────────────────────────────────────────
# MUST be at least 64 characters for HS512
JWT_SECRET=replace-with-a-very-long-random-string-at-least-64-characters-long-for-production
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# ── Email / SMTP ─────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@yourhospital.com
MAIL_PASSWORD=your_app_password_here
MAIL_FROM=noreply@yourhospital.com

# ── Queue Limits ─────────────────────────────────────────────
QUEUE_MAX_SIZE=50
QUEUE_ALERT_THRESHOLD=40

# ── Server ───────────────────────────────────────────────────
PORT=8080
